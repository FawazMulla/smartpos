{
  "id": "com.smartpos.app",
  "name": "SmartPOS Ecosystem",
  "short_name": "SmartPOS",
  "description": "Smart shopping cart scanner, real-time cart sync, live inventory management and express checkout.",
  "start_url": "/mobile",
  "scope": "/",
  "display": "standalone",
  "display_override": ["standalone", "minimal-ui"],
  "orientation": "portrait",
  "background_color": "#003c33",
  "theme_color": "#003c33",
  "categories": ["shopping", "productivity", "utilities"],
  "icons": [
    {
      "src": "/static/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "/static/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "/static/apple-touch-icon.png",
      "sizes": "180x180",
      "type": "image/png",
      "purpose": "any"
    }
  ],
  "shortcuts": [
    {
      "name": "Scan Cart",
      "short_name": "Scan",
      "description": "Scan a SmartPOS cart QR code",
      "url": "/mobile?action=scan",
      "icons": [{ "src": "/static/icon-192.png", "sizes": "192x192" }]
    },
    {
      "name": "Admin Dashboard",
      "short_name": "Admin",
      "description": "Management & Inventory Console",
      "url": "/",
      "icons": [{ "src": "/static/icon-192.png", "sizes": "192x192" }]
    }
  ]
}
